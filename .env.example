# Full setup for Option A vs Option B: see docs/README.md
#
# Option A — Gemini API (Google AI Studio / API key with Generative Language API enabled)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Option B — Vertex AI (service account: set GOOGLE_APPLICATION_CREDENTIALS to your JSON key path)
# Leave GEMINI_API_KEY unset when using Vertex.
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
# GEMINI_MODEL=gemini-2.0-flash-001
